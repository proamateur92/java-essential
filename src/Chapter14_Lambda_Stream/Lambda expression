1.2 람다식 작성하기

람다식은 '익명 함수'답게 메서드에서 이름과 반환타입을 제거하고 매개변수 선언부와 몸통{} 사이에 '->'를 추가한다.

(매개변수 선언) -> {
  문장
}

======================================
int max(int a, int b) {
  return a>b?a:b;
}

(a, b) -> a>b?a:b
======================================
void printVar(String name, int i) {
  System.out.println(name+"="+i);
}

(name, i) -> System.out.println(name+"="+i)
======================================
int square(int x) {
  return x*x;
}

x -> x*x
======================================
int roll() {
  return (int)(Math.random()*6);
}

() -> (int)(Math.random()*6)
======================================
int sumArr(int[] arr) {
  int sum=0;
  for(int i:arr)
    sum+=i;
  return sum;
}


(arr) -> { 
  int sum=0; 
  for(int i:arr)
    sum+=i;
  return sum;
 }
